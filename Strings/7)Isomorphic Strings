approach- We compare if the characters of the 2 strings have appeared at the same index or not. if they did appear
at the same index, that means they follow the same pattern and are isomorphic.

if not, we return false and then update the index.

class Solution {
public:
    bool isIsomorphic(string s, string t) {
        vector<int> m1(256, -1), m2(256, -1);
        int n = s.size();

        for(int i = 0; i<n; i++){
            if(m1[s[i]] != m2[t[i]]) return false;

            m1[s[i]] = i;
            m2[t[i]] = i;
        }
        return true;
    }
};
